[
  {
    "name": "/start sends welcome with main menu and Help button routes to help text",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Welcome! Commands: /flip /flip3 /help",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Help", "callback_data": "help" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "help" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Available commands:\n/start — Welcome message\n/flip — Flip a coin\n/flip3 — Flip three coins\n/help — This help text"
            }
          }
        ]
      }
    ]
  }
]